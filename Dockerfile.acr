# Cloud build (az acr build) — self-contained: builds the Flutter web app
# in-image, then serves it via nginx. The original ./Dockerfile expects a
# pre-built build/web (local build); this one needs no local Flutter.
#
#   az acr build --registry wiosacr --image wios-flutter:latest \
#     --file Dockerfile.acr \
#     --build-arg GATEWAY_URL=https://<gateway-fqdn> \
#     --build-arg SIM_WS_URL=wss://<gateway-fqdn>/ws/sim  .

# ── Stage 1: build Flutter web ──────────────────────────────────────────────
FROM ghcr.io/cirruslabs/flutter:stable AS build
# Flutter's SDK is a git repo owned by another user; allow it when running as root.
RUN git config --global --add safe.directory '*'
WORKDIR /app
COPY . .
ARG GATEWAY_URL
ARG SIM_WS_URL
ARG BUILD_ID=dev
RUN flutter pub get \
 && flutter build web --release \
      --dart-define=ENV=prod \
      --dart-define=GATEWAY_URL=${GATEWAY_URL} \
      --dart-define=SIM_WS_URL=${SIM_WS_URL} \
      --dart-define=BUILD_ID=${BUILD_ID}

# ── Stage 2: serve with nginx ───────────────────────────────────────────────
FROM nginx:1.27-alpine
RUN rm -rf /usr/share/nginx/html/*
COPY --from=build /app/build/web /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
